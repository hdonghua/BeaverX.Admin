{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "BeaverX.Admin",
    "Audience": "BeaverX.Admin",
    "SecretKey": "BeaverX.Admin.Development.SecretKey.Must.Be.At.Least.32.Chars",
    "ExpiresInMinutes": 30,
    "RefreshTokenExpiresInDays": 1
  },
  "Minio": {
    "Endpoint": "http://127.0.0.1:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "beaverx-admin",
    "UseSsl": false,
    "MaxFileSizeMb": 10,
    "PresignedUrlExpirySeconds": 604800
  }
}
