{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "BeaverX.Admin",
    "Audience": "BeaverX.Admin",
    "SecretKey": "BeaverX.Admin.Development.SecretKey.Must.Be.At.Least.32.Chars",
    "ExpiresInMinutes": 30,
    "RefreshTokenExpiresInDays": 1
  },
  "Cache": {
    "Driver": "Memory",
    "KeyPrefix": "beaverx:admin:",
    "DefaultExpirationSeconds": 3600
  },
  "Minio": {
    "Endpoint": "http://127.0.0.1:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "beaverx-admin",
    "UseSsl": false,
    "MaxFileSizeMb": 10,
    "PresignedUrlExpirySeconds": 604800
  }
}
